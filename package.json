{
  "name": "slack-codepilot",
  "version": "0.1.0",
  "description": "Slack AI agent bot for automating feature/bug fix requests",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format --write src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "^0.14.4",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@slack/bolt": "^4.1.0",
    "@slack/types": "^2.20.0",
    "@slack/web-api": "^7.14.1",
    "bullmq": "^5.30.1",
    "dotenv": "^16.4.7",
    "google-auth-library": "^10.6.1",
    "ioredis": "^5.4.2",
    "openai": "^4.77.0",
    "pino": "^9.6.0",
    "prom-client": "^15.1.3",
    "simple-git": "^3.32.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^22.10.5",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.1.0"
  },
  "packageManager": "pnpm@9.15.4"
}
