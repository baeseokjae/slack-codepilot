# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# Redis
REDIS_URL=redis://localhost:6379

# AI (Qwen3-Coder via OpenAI-compatible API)
QWEN_API_KEY=your-qwen-api-key
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3-coder

# Cloudflare Tunnel
CF_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# Logging
LOG_LEVEL=info

# GitHub App (Phase 2 - Worker)
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY=base64-encoded-pem-key
GITHUB_INSTALLATION_ID=12345678
GIT_WORKSPACE_DIR=/tmp/codepilot-workspaces
CODE_GEN_MAX_TOKENS=8192
