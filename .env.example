# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=4000

# AI provider: 'openai' (default, OpenAI-compatible API) or 'vertex' (Google Cloud Gemini)
AI_PROVIDER=openai

# OpenAI-compatible API — required when AI_PROVIDER=openai
# Works with any OpenAI-compatible provider (OpenAI, DashScope/Qwen, Ollama, Mistral, etc.)
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3-coder

# Vertex AI (Google Cloud Gemini) — required when AI_PROVIDER=vertex
# Authentication uses Application Default Credentials (run: gcloud auth application-default login)
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=google/gemini-2.5-flash

# Cloudflare Tunnel
CF_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# Logging
LOG_LEVEL=info

# GitHub App (Phase 2 - Worker)
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY=base64-encoded-pem-key
GITHUB_INSTALLATION_ID=12345678
GITHUB_DEFAULT_ORG=your-org
GITHUB_REVIEW_TEAM=backend-team
GIT_WORKSPACE_DIR=/tmp/codepilot-workspaces
CODE_GEN_MAX_TOKENS=16384

# TTL (optional, in seconds)
THREAD_TTL_SECONDS=3600
PENDING_TTL_SECONDS=1800

# Slack → GitHub user mapping (optional, format: "SLACK_USER_ID:github-username,...")
# Priority over email-based lookup. Use when GitHub emails are private.
SLACK_GITHUB_USER_MAP=SLACK_USER_ID:github-username

# Notion Integration (optional — if not set, Notion step is skipped)
# Create an integration at https://www.notion.so/my-integrations
NOTION_API_KEY=ntn_your-notion-integration-token
# Database ID from the Notion Issues database URL
# (e.g., https://www.notion.so/<workspace>/<database_id>?v=...)
NOTION_ISSUE_DATABASE_ID=your-notion-database-id
