# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=4000

# AI provider: 'openai' (default, uses Qwen/DashScope) or 'vertex' (Google Cloud Gemini)
AI_PROVIDER=openai

# AI (Qwen3-Coder via OpenAI-compatible API) — required when AI_PROVIDER=openai
QWEN_API_KEY=your-qwen-api-key
QWEN_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3-coder

# Vertex AI (Google Cloud Gemini) — required when AI_PROVIDER=vertex
# Authentication uses Application Default Credentials (run: gcloud auth application-default login)
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=google/gemini-2.5-flash

# Cloudflare Tunnel
CF_TUNNEL_TOKEN=your-cloudflare-tunnel-token

# Logging
LOG_LEVEL=info

# GitHub App (Phase 2 - Worker)
GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY=base64-encoded-pem-key
GITHUB_INSTALLATION_ID=12345678
GIT_WORKSPACE_DIR=/tmp/codepilot-workspaces
CODE_GEN_MAX_TOKENS=8192
